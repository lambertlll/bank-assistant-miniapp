/**app.wxss**/
/* 银行业务助手 - 高端金融风格全局样式 */

page {
  background-color: #f8f9fb;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #2c3e50;
  font-size: 28rpx;
  --color-primary: #0d2137;
  --color-primary-light: #1a3a5c;
  --color-gold: #c9a96e;
  --color-gold-light: #d4b87a;
  --color-bg: #f8f9fb;
  --color-card: #ffffff;
  --color-text: #1a2a3a;
  --color-text-secondary: #6b7c8d;
  --color-text-muted: #9aacbd;
  --color-border: #e8edf3;
  --color-success: #2e8b57;
  --color-error: #c0392b;
  --shadow-sm: 0 2rpx 8rpx rgba(13, 33, 55, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(13, 33, 55, 0.06);
  --shadow-lg: 0 16rpx 48rpx rgba(13, 33, 55, 0.08);
  --shadow-xl: 0 24rpx 64rpx rgba(13, 33, 55, 0.12);
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 高端卡片样式 */
.card {
  background-color: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(201, 169, 110, 0.3), transparent);
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
  position: relative;
  letter-spacing: 1rpx;
}

.title::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 0;
  width: 60rpx;
  height: 3rpx;
  background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light));
  border-radius: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

/* 主按钮 - 渐变金色边框 */
.button-primary {
  background: linear-gradient(135deg, #0d2137 0%, #1a3a5c 50%, #0d2137 100%);
  color: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 32rpx;
  border: none;
  letter-spacing: 3rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(13, 33, 55, 0.2);
}

.button-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(201, 169, 110, 0.15), transparent);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

.button-primary:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(13, 33, 55, 0.15);
}

.button-primary[disabled] {
  background: linear-gradient(135deg, #a0b4c8 0%, #b8cce0 100%);
  color: rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

.button-primary[disabled]::after {
  display: none;
}

.button-secondary {
  background-color: var(--color-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.button-secondary:active {
  background-color: #f0f4f8;
  transform: scale(0.97);
}

/* 加载动画 - 脉冲圆点 */
.loading-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-gold);
  animation: pulse 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes pulse {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 波纹加载 */
.loading-ripple {
  width: 80rpx;
  height: 80rpx;
  position: relative;
  margin-bottom: 32rpx;
}

.loading-ripple::before,
.loading-ripple::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 3rpx solid var(--color-gold);
  border-radius: 50%;
  animation: ripple 1.5s ease-out infinite;
}

.loading-ripple::after {
  animation-delay: 0.5s;
}

@keyframes ripple {
  0% {
    transform: scale(0.5);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top: 4rpx solid var(--color-gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: 16rpx;
  font-weight: 500;
}

.loading-progress {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 12rpx;
}

/* 进度条 */
.progress-bar {
  width: 400rpx;
  height: 6rpx;
  background-color: var(--color-border);
  border-radius: 3rpx;
  margin-top: 24rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light));
  border-radius: 3rpx;
  transition: width 0.5s ease;
  position: relative;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 20rpx;
  height: 100%;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 3rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 60rpx;
  color: var(--color-text-muted);
}

.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 32rpx;
  position: relative;
}

/* CSS 绘制的空状态插画 - 文件图标 */
.empty-illustration::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 50rpx;
  width: 100rpx;
  height: 130rpx;
  border: 4rpx solid var(--color-border);
  border-radius: 8rpx;
  background: var(--color-bg);
}

.empty-illustration::after {
  content: '';
  position: absolute;
  top: 50rpx;
  left: 70rpx;
  width: 60rpx;
  height: 6rpx;
  background: var(--color-border);
  border-radius: 3rpx;
  box-shadow: 0 16rpx 0 var(--color-border), 0 32rpx 0 var(--color-border);
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-top: 12rpx;
}

/* 错误状态 */
.error {
  color: var(--color-error);
  padding: 24rpx;
  background-color: #fdf2f2;
  border-radius: var(--radius-md);
  margin-top: 20rpx;
  border-left: 6rpx solid var(--color-error);
  font-size: 26rpx;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-bottom: 32rpx;
  padding: 0 40rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.step-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  transition: all 0.3s;
}

.step-dot.active {
  background: var(--color-gold);
  box-shadow: 0 0 0 8rpx rgba(201, 169, 110, 0.15);
}

.step-dot.completed {
  background: var(--color-success);
}

.step-dot-inner {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
}

.step-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  white-space: nowrap;
}

.step-label.active {
  color: var(--color-gold);
  font-weight: 500;
}

.step-line {
  height: 3rpx;
  flex: 1;
  background: var(--color-border);
  margin: 0 -8rpx;
  margin-top: -16rpx;
}

.step-line.active {
  background: var(--color-gold);
}

/* 涟漪效果 */
@keyframes btn-ripple {
  0% {
    transform: scale(0);
    opacity: 0.4;
  }
  100% {
    transform: scale(2.5);
    opacity: 0;
  }
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f2f5 25%, #e8eaed 50%, #f0f2f5 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 16rpx;
}

.skeleton-title {
  height: 40rpx;
  width: 60%;
  margin-bottom: 24rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

/* 页面过渡 */
.page-enter {
  animation: fadeInUp 0.3s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 弹窗动画 */
@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.85);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
