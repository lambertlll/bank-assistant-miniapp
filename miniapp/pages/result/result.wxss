/* pages/result/result.wxss */
/* 银行业务助手 - 结果页样式 */

/* 结果头部 */
.result-header {
  border-left: 8rpx solid #1a3a5c;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a3a5c;
  margin-bottom: 12rpx;
}

.result-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #8fa8c0;
  background: #f0f4f8;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

/* 结果内容 */
.result-body {
  min-height: 300rpx;
}

.plain-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 操作按钮栏 */
.actions-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 8rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(26, 58, 92, 0.06);
  border: none;
  line-height: 1.4;
}

.action-btn::after {
  border: none;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.copy-btn {
  color: #1a3a5c;
}

.share-btn {
  color: #2d6aa0;
}

.back-btn {
  color: #5a7a9a;
}

.action-btn:active {
  background: #f0f4f8;
  transform: scale(0.96);
}

/* 错误区域 */
.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.error-icon-large {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-message {
  font-size: 28rpx;
  color: #d32f2f;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.button-retry {
  background: #fff;
  color: #d32f2f;
  border: 2rpx solid #d32f2f;
  border-radius: 12rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

.button-retry:active {
  background: #fef0f0;
}
