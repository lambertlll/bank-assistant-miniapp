/* pages/history/history.wxss */
/* 银行业务助手 - 历史记录页（时间线风格） */

/* ===== 空状态 ===== */
.empty-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 80rpx 48rpx;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 40rpx;
}

.empty-illustration-wrap {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  margin-bottom: 36rpx;
}

/* CSS 绘制的空状态插画 - 文档 + 时钟 */
.empty-doc {
  position: absolute;
  top: 20rpx;
  left: 30rpx;
  width: 100rpx;
  height: 130rpx;
  background: var(--color-bg);
  border: 3rpx solid var(--color-border);
  border-radius: 8rpx;
}

.empty-doc-fold {
  position: absolute;
  top: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  background: linear-gradient(135deg, var(--color-bg) 50%, var(--color-border) 50%);
  border-bottom-left-radius: 4rpx;
}

.empty-doc-line {
  position: absolute;
  left: 16rpx;
  height: 4rpx;
  background: var(--color-border);
  border-radius: 2rpx;
}

.empty-doc-line.l1 { top: 40rpx; width: 60rpx; }
.empty-doc-line.l2 { top: 56rpx; width: 50rpx; }
.empty-doc-line.l3 { top: 72rpx; width: 40rpx; }

.empty-clock {
  position: absolute;
  bottom: 20rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  border: 3rpx solid var(--color-gold);
  border-radius: 50%;
}

.empty-clock-hand {
  position: absolute;
  bottom: 50%;
  left: 50%;
  transform-origin: bottom center;
  background: var(--color-gold);
  border-radius: 2rpx;
}

.empty-clock-hand.h {
  width: 3rpx;
  height: 16rpx;
  transform: translateX(-50%) rotate(-30deg);
}

.empty-clock-hand.m {
  width: 3rpx;
  height: 22rpx;
  transform: translateX(-50%) rotate(60deg);
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-bottom: 36rpx;
}

.empty-action-btn {
  background: linear-gradient(135deg, #0d2137 0%, #1a3a5c 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 56rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(13, 33, 55, 0.15);
}

.empty-action-btn:active {
  transform: scale(0.96);
}

/* ===== 时间线头部 ===== */
.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 0 8rpx;
}

.timeline-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.timeline-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
  background: var(--color-card);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}

/* ===== 时间线列表 ===== */
.timeline-list {
  padding-bottom: 20rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 4rpx;
}

/* 时间线轨道 */
.timeline-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 32rpx;
  flex-shrink: 0;
  padding-top: 36rpx;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.timeline-dot.dot-completed {
  background: var(--color-success);
  box-shadow: 0 0 0 6rpx rgba(46, 139, 87, 0.12);
}

.timeline-dot.dot-failed {
  background: var(--color-error);
  box-shadow: 0 0 0 6rpx rgba(192, 57, 43, 0.12);
}

.timeline-dot.dot-processing {
  background: var(--color-gold);
  box-shadow: 0 0 0 6rpx rgba(201, 169, 110, 0.15);
  animation: pulse-dot 2s infinite;
}

@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 0 6rpx rgba(201, 169, 110, 0.15); }
  50% { box-shadow: 0 0 0 12rpx rgba(201, 169, 110, 0.08); }
}

.timeline-line {
  width: 3rpx;
  flex: 1;
  background: linear-gradient(180deg, var(--color-border), transparent);
  margin-top: 8rpx;
}

/* 时间线卡片 */
.timeline-card {
  flex: 1;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s;
}

.timeline-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.timeline-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.timeline-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.status-completed {
  background: rgba(46, 139, 87, 0.08);
  color: var(--color-success);
}

.status-completed .status-dot {
  background: var(--color-success);
}

.status-failed {
  background: rgba(192, 57, 43, 0.08);
  color: var(--color-error);
}

.status-failed .status-dot {
  background: var(--color-error);
}

.status-processing {
  background: rgba(201, 169, 110, 0.1);
  color: var(--color-gold);
}

.status-processing .status-dot {
  background: var(--color-gold);
  animation: pulse-dot 2s infinite;
}

.timeline-card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.meta-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.meta-time-icon {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid var(--color-text-muted);
  border-radius: 50%;
  position: relative;
}

.meta-time-icon::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 50%;
  width: 2rpx;
  height: 5rpx;
  background: var(--color-text-muted);
  transform: translateX(-50%);
}

.meta-type-badge {
  font-size: 20rpx;
  color: var(--color-primary-light);
  background: rgba(26, 58, 92, 0.06);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.timeline-preview {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  border-left: 3rpx solid var(--color-gold);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.timeline-card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
}

.view-detail-text {
  font-size: 22rpx;
  color: var(--color-gold);
  font-weight: 500;
}

.view-detail-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid var(--color-gold);
  border-right: 2rpx solid var(--color-gold);
  transform: rotate(45deg);
}

/* ===== 清空按钮 ===== */
.clear-section {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.clear-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: transparent;
  color: var(--color-text-muted);
  font-size: 24rpx;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
}

.clear-btn:active {
  color: var(--color-error);
  background: rgba(192, 57, 43, 0.04);
}

.clear-icon {
  width: 20rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 0 4rpx 4rpx;
  border-top: none;
  position: relative;
}

.clear-icon::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: -4rpx;
  width: 28rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 2rpx;
}

.clear-icon::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 12rpx;
  background: currentColor;
}
